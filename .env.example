# ─────────────────────────────────────────────────────────────────────────────
# Aurixa Mission Control — environment template
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# VITE_-prefixed vars are exposed to the browser bundle — keep secrets OUT of them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (client-public: anon/publishable key + URL) ─────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# ── Supabase (server) ────────────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
SUPABASE_ANON_KEY="your-anon-publishable-key"
# SECRET — bypasses RLS. Server-only. Never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Supabase Management API (provisioning clone backends) ────────────────────
SB_MGMT_API_TOKEN="your-supabase-management-api-token"   # SECRET
SB_ORG_ID="your-supabase-org-id"

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_or_test_..."                  # SECRET
STRIPE_WEBHOOK_SECRET="whsec_..."                        # SECRET

# ── GitHub App (clone repo automation) ───────────────────────────────────────
GITHUB_APP_ID="123456"
GITHUB_APP_INSTALLATION_ID="12345678"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"  # SECRET
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"       # SECRET

# ── Cloudflare (clone DNS/Pages provisioning) ────────────────────────────────
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"         # SECRET

# ── AI gateway ───────────────────────────────────────────────────────────────
LOVABLE_API_KEY="your-ai-gateway-key"                    # SECRET

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY="your-vapid-public-key"
# VAPID_PRIVATE_KEY is configured as a Supabase Edge Function secret (push-fanout), not here.

# ── Cron / scheduled hooks shared secret ─────────────────────────────────────
# NOTE: today the /hooks/* endpoints accept the Supabase publishable key; Phase 1
# replaces that with a dedicated CRON_SECRET. DRIFT_REFRESH_TOKEN is the existing
# dedicated secret used by /hooks/drift-refresh.
DRIFT_REFRESH_TOKEN="your-cron-shared-secret"            # SECRET

# ── App ──────────────────────────────────────────────────────────────────────
PUBLIC_APP_URL="https://your-mission-control-domain"
