# ─────────────────────────────────────────────────────────────────────────────
# Aurixa Mission Control — environment template
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# VITE_-prefixed vars are exposed to the browser bundle — keep secrets OUT of them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (client-public: anon/publishable key + URL) ─────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# ── Supabase (server) ────────────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
SUPABASE_ANON_KEY="your-anon-publishable-key"
# SECRET — bypasses RLS. Server-only. Never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Clone credential encryption (optional, opt-in) ───────────────────────────
# When set, stored clone backend secrets (service_role_key, db_pass) are
# AES-256-GCM encrypted at rest. Leave unset to keep the previous plaintext
# behavior; existing rows are decrypted transparently once enabled.
CREDENTIALS_ENC_KEY="a-long-random-encryption-secret"    # SECRET

# ── Supabase Management API (provisioning clone backends) ────────────────────
SB_MGMT_API_TOKEN="your-supabase-management-api-token"   # SECRET
SB_ORG_ID="your-supabase-org-id"

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_or_test_..."                  # SECRET
STRIPE_WEBHOOK_SECRET="whsec_..."                        # SECRET

# ── GitHub App (clone repo automation) ───────────────────────────────────────
GITHUB_APP_ID="123456"
GITHUB_APP_INSTALLATION_ID="12345678"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"  # SECRET
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"       # SECRET

# ── Cloudflare (clone DNS/Pages provisioning) ────────────────────────────────
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"         # SECRET

# ── AI gateway ───────────────────────────────────────────────────────────────
LOVABLE_API_KEY="your-ai-gateway-key"                    # SECRET

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY="your-vapid-public-key"
# VAPID_PRIVATE_KEY is configured as a Supabase Edge Function secret (push-fanout), not here.

# ── Cron / scheduled hooks shared secret ─────────────────────────────────────
# All /hooks/* endpoints require this dedicated secret as a Bearer token (the
# public publishable/anon key is NO LONGER accepted). Set the SAME value as the
# Postgres GUC so pg_cron jobs can send it:
#   ALTER DATABASE postgres SET app.settings.cron_secret = '<same value>';
CRON_SECRET="your-cron-shared-secret"                    # SECRET
# Deprecated fallback, still accepted during rollout (used by /hooks/drift-refresh).
DRIFT_REFRESH_TOKEN="your-cron-shared-secret"            # SECRET

# ── Waitlist lead capture (website → Mission Control tie-up) ─────────────────
# Shared secret for server-to-server lead delivery (e.g. a Make.com HTTP
# module forwarding the waitlist webhook). Requests carrying this value in the
# `x-lead-capture-secret` header (or as a Bearer token) bypass the browser
# origin check and rate limits on POST /api/public/leads/capture.
LEAD_CAPTURE_SECRET="your-lead-capture-shared-secret"    # SECRET
# Extra comma-separated browser origins allowed to dual-write leads (the
# aurixasystems.com.au origins and localhost:3000 are always allowed).
# LEAD_CAPTURE_ALLOWED_ORIGINS="https://staging.aurixasystems.com.au"

# ── App ──────────────────────────────────────────────────────────────────────
PUBLIC_APP_URL="https://your-mission-control-domain"

# ── Customer storefront (user-attributed pricing workflow) ───────────────────
# Full URL of the CUSTOMER-FACING pricing page on the Aurixa Systems website.
# All user-centric monetisation (tokens, plans, seats — prime + clones) lands
# here; Mission Control serves no /pricing route of its own (operators use the
# /billing/* consoles). Handoff deep links and packs topup_urls are minted
# against this base (unset = the default storefront domain in
# src/lib/storefront.ts), and storefront checkout success/cancel redirects
# return to <this URL>/success|/cancel.
PUBLIC_PRICING_SITE_URL="https://www.aurixasystems.com.au/pricing"
